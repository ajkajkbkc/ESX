                  <AlwaysBuild>0</AlwaysBuild>
                  <GenerateAssemblyFile>0</GenerateAssemblyFile>
                  <AssembleAssemblyFile>0</AssembleAssemblyFile>
                  <PublicsOnly>0</PublicsOnly>
