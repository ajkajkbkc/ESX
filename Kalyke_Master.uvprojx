            <DataAddressRange>0x20000000</DataAddressRange>
            <pXoBase></pXoBase>
            <ScatterFile>MIMXRT1062xxxxx_sdram.scf</ScatterFile>
            <IncludeLibs></IncludeLibs>
            <IncludeLibsPath></IncludeLibsPath>
            <Misc>--remove --predefine="-D__stack_size__=1000" --predefine="-D__heap_size__=25600"
--remove</Misc>
            <LinkerInputFile></LinkerInputFile>
            <DisabledWarnings>6314</DisabledWarnings>
          </LDads>
        </TargetArmAds>
      </TargetOption>
